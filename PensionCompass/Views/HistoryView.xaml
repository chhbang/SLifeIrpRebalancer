<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PensionCompass.Views.HistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:webview="using:Microsoft.UI.Xaml.Controls"
    xmlns:history="using:PensionCompass.Core.History"
    mc:Ignorable="d">

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="리밸런싱 이력" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBlock
            Grid.Row="1"
            Style="{StaticResource BodyTextBlockStyle}"
            TextWrapping="Wrap"
            Text="AI 리밸런싱 화면에서 '이력에 저장'을 누른 회차들이 여기에 쌓입니다. 동기화 폴더가 설정되어 있으면 그 폴더를 우선 살펴보고, LocalState\History\ 도 함께 스캔합니다." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Button Content="새로고침" Click="RefreshButton_Click" />
            <Button Content="PC에서 파일 불러오기" Click="LoadExternalButton_Click"
                    ToolTipService.ToolTip="동기화 폴더 밖 임의 위치의 RebalanceSession JSON 파일 열기" />
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>

        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    CornerRadius="4">
                <ListView
                    ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="12,8" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="history:RebalanceSessionEntry">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{x:Bind DisplayLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTipService.ToolTip="{x:Bind FilePath}">
                                    <Run Text="보유 " /><Run Text="{x:Bind Meta.HoldingsCount}" /><Run Text="개  ·  사고 수준 " /><Run Text="{x:Bind Meta.ThinkingLevel}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{x:Bind ViewModel.SelectedSummary, Mode=OneWay}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Content="다음 리밸런싱에 이 추천 참고하기"
                            Click="UseAsPriorButton_Click"
                            Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="PDF로 내보내기" Click="ExportPdfButton_Click" />
                    <Button Content="삭제" Click="DeleteButton_Click" />
                </StackPanel>

                <Border Grid.Row="2"
                        Background="White"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <webview:WebView2 x:Name="ResponseWebView" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
