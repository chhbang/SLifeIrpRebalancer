<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PensionCompass.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="720" HorizontalAlignment="Left">
            <TextBlock Text="환경 설정" Style="{StaticResource TitleTextBlockStyle}" />

            <TextBlock
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap"
                Text="AI 서비스, API Key, 모델 ID, 사고 수준을 설정합니다. 변경 내용은 즉시 자동 저장되어 다음 실행에도 유지됩니다." />

            <RadioButtons
                Header="AI 공급자 *"
                SelectedIndex="{x:Bind ViewModel.ProviderIndex, Mode=TwoWay}"
                MaxColumns="3">
                <x:String>Claude</x:String>
                <x:String>Gemini</x:String>
                <x:String>GPT</x:String>
            </RadioButtons>

            <StackPanel Spacing="6">
                <TextBlock Text="API Key (공급자별)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="12" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Claude" VerticalAlignment="Center" />
                    <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="ClaudeApiKeyBox" PlaceholderText="sk-ant-..." PasswordChanged="ClaudeApiKeyBox_PasswordChanged" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Gemini" VerticalAlignment="Center" />
                    <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="GeminiApiKeyBox" PlaceholderText="AIza..." PasswordChanged="GeminiApiKeyBox_PasswordChanged" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="GPT" VerticalAlignment="Center" />
                    <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="GptApiKeyBox" PlaceholderText="sk-..." PasswordChanged="GptApiKeyBox_PasswordChanged" />
                </Grid>
                <TextBlock
                    Text="공급자마다 별도의 API Key가 저장되며, 현재 선택된 공급자의 키만 사용됩니다. API Key는 Windows 자격증명 보관소(PasswordVault)에 사용자 계정으로 암호화되어 보관됩니다. 다만 같은 사용자 세션 안에서 도는 다른 프로그램이 동일 API로 꺼내 가는 것까진 막지 못하니, 공용 PC에서는 여전히 사용을 피해주세요."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="모델 ID" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="12" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Claude" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{x:Bind ViewModel.ClaudeModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="claude-opus-4-7" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Gemini" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{x:Bind ViewModel.GeminiModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="gemini-2.5-pro" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="GPT" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{x:Bind ViewModel.GptModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="gpt-5" />
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button
                        Content="현재 공급자의 모델 목록 가져오기"
                        Click="ListModelsButton_Click" />
                </StackPanel>
                <TextBlock
                    Text="모델 ID는 각 공급자의 API 문서 표기를 그대로 입력하세요. '목록 가져오기'는 현재 선택된 공급자와 그 공급자의 API Key로 사용 가능한 모델을 조회합니다."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <RadioButtons
                    Header="사고 수준 (reasoning effort) *"
                    SelectedIndex="{x:Bind ViewModel.ThinkingLevelIndex, Mode=TwoWay}"
                    MaxColumns="4">
                    <x:String>끔</x:String>
                    <x:String>낮음</x:String>
                    <x:String>보통</x:String>
                    <x:String>최상</x:String>
                </RadioButtons>
                <TextBlock
                    Text="최상은 깊이 있는 답변을 주지만 응답이 1-3분 걸릴 수 있습니다. 리밸런싱은 자주 하는 작업이 아니니 기본값(최상) 그대로 두기를 권장합니다. 공급자별로 Anthropic은 thinking budget, OpenAI는 reasoning_effort, Gemini는 thinkingBudget으로 매핑됩니다."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="동기화 폴더 (선택)" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{x:Bind ViewModel.SyncFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="비워두면 동기화 안 함 (LocalState만 사용). 예: D:\OneDrive\PensionCompass" />
                    <Button Grid.Column="1" Content="폴더 선택" Click="PickSyncFolderButton_Click" />
                    <Button Grid.Column="2" Content="비우기" Click="ClearSyncFolderButton_Click" />
                </Grid>
                <TextBlock
                    Text="이 폴더를 OneDrive / Google Drive 데스크톱 / Dropbox 등 클라우드 동기 폴더로 지정하면, 계좌 정보·상품 카탈로그·리밸런싱 이력이 다른 PC와 자동으로 공유됩니다. 폴더에는 보유 잔고·수익률 등 금융 정보가 포함되니 본인만 접근 가능한 위치를 선택하세요. API Key는 이 폴더에 절대 기록되지 않습니다."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
