<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PensionCompass.Views.DataPreparationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PensionCompass.ViewModels"
    xmlns:models="using:PensionCompass.Core.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Shared column widths so headers and rows stay aligned across the ListView. -->
        <x:Double x:Key="ColManager">160</x:Double>
        <x:Double x:Key="ColCode">90</x:Double>
        <x:Double x:Key="ColName">360</x:Double>
        <x:Double x:Key="ColRate">90</x:Double>
        <x:Double x:Key="ColMaturity">80</x:Double>
        <x:Double x:Key="ColRiskGrade">110</x:Double>
        <x:Double x:Key="ColReturn">80</x:Double>
        <!-- Aligns the first action button across the catalog/portfolio rows by giving both
             section labels the same column width regardless of label text length. -->
        <x:Double x:Key="ColSectionLabel">100</x:Double>
    </Page.Resources>

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="상품 데이터 준비" Style="{StaticResource TitleTextBlockStyle}" />

        <TextBlock
            Grid.Row="1"
            Style="{StaticResource BodyTextBlockStyle}"
            TextWrapping="Wrap"
            Text="삼성생명 IRP 상품 목록 HTML을 불러와 원리금보장형 / 펀드 CSV로 변환합니다. 펀드 수익률 컬럼은 HTML 한 부에 1개 기간만 들어 있으므로, 모든 기간(1개월/3개월/6개월/1년/3년)을 채우려면 정렬을 바꿔가며 여러 번 저장해 가져와야 합니다." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="상품 카탈로그" VerticalAlignment="Center" Width="{StaticResource ColSectionLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Button
                x:Name="LoadHtmlButton"
                Content="HTML 불러오기 (덮어쓰기)"
                Click="LoadHtmlButton_Click"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                x:Name="MergeHtmlButton"
                Content="다른 기간 HTML 추가 머지"
                Click="MergeHtmlButton_Click"
                IsEnabled="{x:Bind ViewModel.HasCatalog, Mode=OneWay}" />
            <Button
                x:Name="LoadCsvButton"
                Content="CSV 폴더에서 불러오기"
                Click="LoadCsvButton_Click" />
            <Button
                x:Name="SaveCsvButton"
                Content="CSV 폴더로 저장"
                Click="SaveCsvButton_Click"
                IsEnabled="{x:Bind ViewModel.HasCatalog, Mode=OneWay}" />
            <Button
                x:Name="ResetCatalogButton"
                Content="카탈로그 초기화"
                Click="ResetCatalogButton_Click"
                IsEnabled="{x:Bind ViewModel.HasCatalog, Mode=OneWay}" />
            <ProgressRing
                IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                Width="24" Height="24"
                VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="내 계좌" VerticalAlignment="Center" Width="{StaticResource ColSectionLabel}" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Button
                x:Name="LoadPortfolioHtmlButton"
                Content="HTML 불러오기 (덮어쓰기)"
                Click="LoadPortfolioHtmlButton_Click"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                x:Name="LoadPortfolioCsvButton"
                Content="CSV 폴더에서 불러오기"
                Click="LoadPortfolioCsvButton_Click" />
            <Button
                x:Name="SavePortfolioCsvButton"
                Content="CSV 폴더로 저장"
                Click="SavePortfolioCsvButton_Click"
                IsEnabled="{x:Bind ViewModel.HasPortfolio, Mode=OneWay}" />
            <Button
                x:Name="PortfolioGuideButton"
                Click="PortfolioGuideButton_Click"
                ToolTipService.ToolTip="삼성생명 홈페이지에서 HTML을 받는 방법 보기">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE946;" />
                    <TextBlock Text="안내" />
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="4" Spacing="4">
            <TextBlock
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />
            <TextBlock
                Text="{x:Bind ViewModel.PeriodSummary, Mode=OneWay}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                Text="{x:Bind ViewModel.SamsungLifeSummary, Mode=OneWay}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock
                Text="{x:Bind ViewModel.PortfolioStatusMessage, Mode=OneWay}"
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap"
                Margin="0,4,0,0" />
        </StackPanel>

        <TabView
            Grid.Row="5"
            IsAddTabButtonVisible="False"
            CanDragTabs="False"
            CanReorderTabs="False"
            TabWidthMode="SizeToContent">

            <TabViewItem Header="원리금보장형" IsClosable="False">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <TextBlock Text="운용사" Width="{StaticResource ColManager}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="상품코드" Width="{StaticResource ColCode}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="상품명" Width="{StaticResource ColName}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="금리" Width="{StaticResource ColRate}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="만기" Width="{StaticResource ColMaturity}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                    </Border>

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.PrincipalGuaranteed, Mode=OneWay}"
                        SelectionMode="None"
                        IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,4" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PrincipalGuaranteedProduct">
                                <StackPanel Orientation="Horizontal" Spacing="0">
                                    <TextBlock Text="{x:Bind AssetManager}" Width="{StaticResource ColManager}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind ProductCode}" Width="{StaticResource ColCode}" />
                                    <TextBlock Text="{x:Bind ProductName}" Width="{StaticResource ColName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind AppliedRate}" Width="{StaticResource ColRate}" />
                                    <TextBlock Text="{x:Bind MaturityTerm}" Width="{StaticResource ColMaturity}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabViewItem>

            <TabViewItem Header="펀드" IsClosable="False">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <TextBlock Text="운용사" Width="{StaticResource ColManager}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="상품코드" Width="{StaticResource ColCode}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="상품명" Width="{StaticResource ColName}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="위험등급" Width="{StaticResource ColRiskGrade}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="1개월" Width="{StaticResource ColReturn}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="3개월" Width="{StaticResource ColReturn}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="6개월" Width="{StaticResource ColReturn}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="1년" Width="{StaticResource ColReturn}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="3년" Width="{StaticResource ColReturn}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                    </Border>

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Funds, Mode=OneWay}"
                        SelectionMode="None"
                        IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="12,4" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FundRow">
                                <StackPanel Orientation="Horizontal" Spacing="0">
                                    <TextBlock Text="{x:Bind AssetManager}" Width="{StaticResource ColManager}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind ProductCode}" Width="{StaticResource ColCode}" />
                                    <TextBlock Text="{x:Bind ProductName}" Width="{StaticResource ColName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind RiskGrade}" Width="{StaticResource ColRiskGrade}" />
                                    <TextBlock Text="{x:Bind Return1Month}" Width="{StaticResource ColReturn}" />
                                    <TextBlock Text="{x:Bind Return3Month}" Width="{StaticResource ColReturn}" />
                                    <TextBlock Text="{x:Bind Return6Month}" Width="{StaticResource ColReturn}" />
                                    <TextBlock Text="{x:Bind Return1Year}" Width="{StaticResource ColReturn}" />
                                    <TextBlock Text="{x:Bind Return3Year}" Width="{StaticResource ColReturn}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabViewItem>
        </TabView>
    </Grid>
</Page>
