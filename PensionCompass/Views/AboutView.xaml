<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PensionCompass.Views.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Left">

            <StackPanel Spacing="4">
                <TextBlock Text="연금나침반" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="VersionText" Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock
                Style="{StaticResource BodyTextBlockStyle}"
                TextWrapping="Wrap"
                Text="삼성생명 IRP(개인형 퇴직연금) 계좌의 펀드/원리금보장형 비중 조정을 AI(Claude·Gemini·GPT)의 도움으로 계획하기 위한 Windows 데스크톱 도구입니다. 사용자가 직접 입력한 보유 현황과 매도 정책, 그리고 삼성생명 공식 사이트에서 내보낸 상품 카탈로그를 바탕으로 한국어 마크다운 형태의 리밸런싱 제안과 PDF 보고서를 생성합니다." />

            <Border Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                    CornerRadius="4" Padding="16" BorderBrush="{ThemeResource SystemFillColorAttentionBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="중요 안내" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap">
                        <Run Text="• 본 앱은 삼성생명보험주식회사와 무관한 비공식(third-party) 도구입니다. 삼성생명에서 만들거나 검수한 적 없으며, 삼성생명의 어떠한 보증도 받지 않습니다." /><LineBreak/>
                        <Run Text="• AI가 생성한 포트폴리오 제안은 참고용 정보이며 투자 권유가 아닙니다. 모든 투자 결정과 그 결과에 대한 책임은 사용자 본인에게 있습니다." /><LineBreak/>
                        <Run Text="• AI 응답의 정확성은 보장되지 않습니다. 실제 매도/매수 전에 반드시 삼성생명 고객센터, 정식 PB 등 전문가의 의견을 함께 확인하세요." />
                    </TextBlock>
                </StackPanel>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock Text="데이터 보관" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap">
                    <Run Text="계좌 정보, 상품 카탈로그, API Key는 모두 사용자 PC의 앱 패키지 LocalState 폴더에만 저장되며 외부로 전송되지 않습니다. AI 호출 시에는 입력하신 보유 현황과 카탈로그가 선택하신 AI 공급자(Anthropic / Google / OpenAI)에 전송됩니다." />
                </TextBlock>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="사용 라이브러리" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap">
                    <Run Text="• Windows App SDK · CommunityToolkit.Mvvm — MIT License" /><LineBreak/>
                    <Run Text="• HtmlAgilityPack — MIT License" /><LineBreak/>
                    <Run Text="• Markdig — BSD-2-Clause License" /><LineBreak/>
                    <Run Text="• QuestPDF — Community MIT License (소규모 / 비영리 사용 무료)" />
                </TextBlock>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="소스 코드" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <HyperlinkButton NavigateUri="https://github.com/chhbang/PensionCompass"
                                 Content="https://github.com/chhbang/PensionCompass" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
